{
  "enable": {
    "type": "bool",
    "description": "启用骚扰上报插件",
    "default": true
  },
  "report_session_id": {
    "type": "string",
    "description": "上报接收会话 ID",
    "default": "",
    "hint": "目标会话执行 /harassment_sid 查看；也可直接执行 /harassment_bind_here"
  },
  "report_receiver_name": {
    "type": "string",
    "description": "接收人称呼，如 主人/狐狸",
    "default": "主人"
  },
  "report_cooldown_seconds": {
    "type": "int",
    "description": "同一来源会话的上报冷却时间（秒）",
    "default": 300,
    "min": 0,
    "max": 86400
  },
  "inject_usage_prompt": {
    "type": "bool",
    "description": "在每轮 LLM 请求前注入工具使用提示",
    "default": true
  },
  "tool_response_mode": {
    "type": "string",
    "description": "调用工具后的处理策略",
    "default": "silent",
    "options": [
      "silent",
      "warn_only",
      "warn_once_then_report",
      "report_then_silent",
      "report_then_inform"
    ],
    "labels": [
      "静默上报",
      "只警告",
      "先警告再上报",
      "上报后静默",
      "上报后告知"
    ],
    "hint": "下拉项已带中文名，细节见 README"
  },
  "natural_language_warn_reply": {
    "type": "bool",
    "description": "警告时按人设自然表达",
    "default": true
  },
  "warn_message_template": {
    "type": "string",
    "description": "警告模板",
    "default": "请立刻停止这种行为。你再这样，我就要告诉{receiver_name}你在骚扰我了。"
  },
  "warn_once_memory_seconds": {
    "type": "int",
    "description": "警告记忆时长（秒）",
    "default": 1800,
    "min": 0,
    "max": 604800,
    "condition": {
      "tool_response_mode": "warn_once_then_report"
    }
  },
  "warn_once_inform_after_report": {
    "type": "bool",
    "description": "二次上报后也告诉对方",
    "default": false,
    "condition": {
      "tool_response_mode": "warn_once_then_report"
    }
  },
  "natural_language_report_reply": {
    "type": "bool",
    "description": "告知已上报时按人设自然表达",
    "default": true
  },
  "report_inform_template": {
    "type": "string",
    "description": "告诉对方已上报的模板",
    "default": "我已经把你刚才的行为报告给{receiver_name}了。"
  },
  "include_message_text": {
    "type": "bool",
    "description": "上报时是否附带触发时的当前消息文本",
    "default": true
  },
  "attach_recent_context_summary": {
    "type": "bool",
    "description": "上报时自动附带最近几轮聊天摘要",
    "default": true
  },
  "recent_context_summary_lines": {
    "type": "int",
    "description": "最近几轮聊天摘要包含的最大行数",
    "default": 6,
    "min": 1,
    "max": 20,
    "condition": {
      "attach_recent_context_summary": true
    }
  },
  "recent_context_summary_max_chars": {
    "type": "int",
    "description": "最近几轮聊天摘要的最大字符数",
    "default": 600,
    "min": 80,
    "max": 4000,
    "condition": {
      "attach_recent_context_summary": true
    }
  },
  "auto_add_sender_to_watchlist": {
    "type": "bool",
    "description": "上报成功后自动把对方加入观察名单",
    "default": true
  },
  "watchlist_max_entries": {
    "type": "int",
    "description": "观察名单最多保留的人数",
    "default": 500,
    "min": 1,
    "max": 5000,
    "condition": {
      "auto_add_sender_to_watchlist": true
    }
  },
  "watchlist_entries": {
    "type": "template_list",
    "description": "观察名单",
    "default": [],
    "hint": "这里可以直接查看、添加、删除或修改观察对象；命令和自动观察也会共用这份名单",
    "obvious_hint": true,
    "templates": {
      "watch_target": {
        "name": "观察对象",
        "items": {
          "key": {
            "type": "string",
            "description": "唯一键",
            "default": "",
            "hint": "建议填写成 平台:用户ID，例如 default:2127074778；如果留空，插件会根据平台和用户 ID 自动补出来"
          },
          "sender_id": {
            "type": "string",
            "description": "用户 ID",
            "default": ""
          },
          "sender_name": {
            "type": "string",
            "description": "显示名称",
            "default": ""
          },
          "platform_id": {
            "type": "string",
            "description": "平台标识",
            "default": "default"
          },
          "note": {
            "type": "string",
            "description": "备注",
            "default": "",
            "hint": "可写上手动备注，或留空让插件用最近一次上报原因补充"
          },
          "enabled": {
            "type": "bool",
            "description": "启用",
            "default": true
          }
        }
      }
    }
  },
  "watchlist_snapshot": {
    "type": "text",
    "description": "旧版观察名单快照（已弃用）",
    "default": "",
    "hint": "已改用下方的“观察名单”可编辑列表；这个旧字段仅用于兼容迁移，后续可忽略",
    "invisible": true
  },
  "owner_report_style": {
    "type": "string",
    "description": "给主人的上报风格",
    "default": "structured",
    "options": [
      "structured",
      "persona_natural"
    ],
    "labels": [
      "结构化告警",
      "人设自然改写"
    ],
    "hint": "下拉项已带中文名"
  },
  "natural_language_report_to_owner": {
    "type": "bool",
    "description": "给主人的上报也按人设改写",
    "default": false,
    "condition": {
      "owner_report_style": "persona_natural"
    }
  },
  "max_excerpt_length": {
    "type": "int",
    "description": "上报中单段文本的最大长度",
    "default": 300,
    "min": 50,
    "max": 2000
  }
}
